<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="@dimen/margi_h"
    tools:context=".MainActivity">

    <ImageView
        android:id="@+id/avatar"
        android:layout_width="@dimen/image_layout_l"
        android:layout_height="@dimen/image_layout_l"
        android:layout_marginBottom="@dimen/margi_h"
        android:contentDescription="@string/author_avatar"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="@id/top_barrier"
        app:layout_constraintStart_toStartOf="parent"
        tools:srcCompat="@sample/posts.json/data/authorAvatar" />

    <TextView
        android:id="@+id/author"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/margi_h"
        android:ellipsize="end"
        android:singleLine="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/published"
        app:layout_constraintEnd_toStartOf="@id/menu"
        app:layout_constraintStart_toEndOf="@id/avatar"
        app:layout_constraintVertical_chainStyle="packed"
        tools:text="@sample/posts.json/data/author" />

    <TextView
        android:id="@+id/published"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/margi_h"
        android:layout_marginEnd="@dimen/margi_h"
        android:layout_marginBottom="0dp"
        app:layout_constraintTop_toBottomOf="@id/author"
        app:layout_constraintBottom_toBottomOf="@id/avatar"
        app:layout_constraintEnd_toStartOf="@id/menu"
        app:layout_constraintStart_toEndOf="@id/avatar"
        tools:text="@sample/posts.json/data/published" />

    <ImageButton
        android:id="@+id/menu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="0dp"
        android:background="@android:color/transparent"
        android:contentDescription="@string/description_post_menu"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/ic_more_vert_24" />

    <androidx.constraintlayout.widget.Barrier
        android:id="@+id/top_barrier"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierDirection="bottom"
        app:constraint_referenced_ids="avatar,published,menu"
        />

    <TextView
        android:id="@+id/content"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="0dp"
        android:autoLink="web"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/top_barrier"
        tools:text="@sample/posts.json/data/content" />

    <androidx.constraintlayout.widget.Barrier
        android:id="@+id/bottom_barrier"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierDirection="bottom"
        app:constraint_referenced_ids="content"
        />

    <ImageView
        android:id="@+id/hearts"
        android:layout_width="@dimen/image_layout_s"
        android:layout_height="@dimen/image_layout_s"
        android:layout_marginBottom="@dimen/margi_h"
        android:contentDescription="@string/hearts"
        app:layout_constraintTop_toBottomOf="@id/bottom_barrier"
        app:layout_constraintStart_toStartOf="parent"
        app:srcCompat="@drawable/ic_topic_heart" />

    <TextView
        android:id="@+id/count_hearts"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/margi_l"
        app:layout_constraintTop_toBottomOf="@id/bottom_barrier"
        app:layout_constraintBottom_toBottomOf="@id/hearts"
        app:layout_constraintStart_toEndOf="@id/hearts"

        tools:text="@sample/posts.json/data/likes" />
    <ImageView
        android:id="@+id/reposts"
        android:layout_width="@dimen/image_layout_s"
        android:layout_height="@dimen/image_layout_s"
        android:layout_marginBottom="@dimen/margi_h"
        android:contentDescription="@string/reposts"
        android:layout_marginHorizontal="@dimen/margi_l"
        app:layout_constraintTop_toBottomOf="@id/bottom_barrier"
        app:layout_constraintStart_toEndOf="@id/count_hearts"
        app:srcCompat="@drawable/ic_topic_repost" />

    <TextView
        android:id="@+id/count_reposts"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/margi_l"
        app:layout_constraintTop_toBottomOf="@id/bottom_barrier"
        app:layout_constraintBottom_toBottomOf="@id/hearts"
        app:layout_constraintStart_toEndOf="@id/reposts"
        tools:text="@sample/posts.json/data/repost" />

    <ImageView
        android:id="@+id/views"
        android:layout_width="@dimen/image_layout_s"
        android:layout_height="@dimen/image_layout_s"
        android:layout_marginBottom="@dimen/margi_h"
        android:contentDescription="@string/reposts"
        android:layout_marginHorizontal="@dimen/margi_l"
        app:layout_constraintTop_toBottomOf="@id/bottom_barrier"
        app:layout_constraintEnd_toStartOf="@id/count_views"
        app:srcCompat="@drawable/ic_topic_show" />

    <TextView
        android:id="@+id/count_views"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/margi_l"
        app:layout_constraintTop_toBottomOf="@id/bottom_barrier"
        app:layout_constraintBottom_toBottomOf="@id/hearts"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="@sample/posts.json/data/views" />


</androidx.constraintlayout.widget.ConstraintLayout>